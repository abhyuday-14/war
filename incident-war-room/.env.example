# Band platform endpoints (these are the SDK's own defaults — only override
# if you're on a self-hosted or staging Band instance)
BAND_REST_URL=https://app.band.ai
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Used directly by Triage (LangGraph/Anthropic), Remediator (Claude Agent SDK),
# and Scribe (Anthropic) for their own LLM calls.
ANTHROPIC_API_KEY=sk-ant-...

# The Band handle of the human on-call engineer allowed to /approve or
# /decline Remediator's proposed actions, e.g. "@maya". Also added to the
# incident room by Sentinel so a human is always present.
ONCALL_HANDLE=@your-handle
